{
    "version": 2,
    "builds": [
        {
            "src": "api/chat.js",
            "use": "@vercel/node"
        },
        {
            "src": "*.svg",
            "use": "@vercel/static"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/chat",
            "dest": "/api/chat.js"
        },
        {
            "src": "/logo.svg",
            "dest": "/logo.svg"
        },
        {
            "src": "/(.*)",
            "dest": "/index.html"
        }
    ]
}